{

  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "App.jsx",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "app.py"
    },
    {
      "src": "/App.jsx",
      "dest": "App.jsx"
    },
    {
      "src": "/(.*)",
      "dest": "index.html"
    }
  ]
}
